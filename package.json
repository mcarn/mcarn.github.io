{
  "name": "mcarn.github.io",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build && touch dist/.nojekyll",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint --ext .astro,.ts,.js,.tsx .",
    "lint:fix": "eslint --ext .astro,.ts,.js,.tsx . --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "astro:upgrade": "pnpm dlx @astrojs/upgrade"
  },
  "dependencies": {
    "@antfu/eslint-config": "0.43.1",
    "@astrojs/check": "^0.9.2",
    "@astrojs/markdoc": "^0.11.3",
    "@astrojs/mdx": "^3.1.3",
    "@astrojs/prism": "3.1.0",
    "@astrojs/rss": "4.0.7",
    "@astrojs/sitemap": "^3.1.6",
    "@astrojs/tailwind": "^5.1.0",
    "@eslint/js": "^9.1.1",
    "astro": "^4.13.3",
    "astro-i18next": "1.0.0-beta.21",
    "astro-icon": "^1.1.0",
    "astro-robots-txt": "^1.0.0",
    "astro-seo": "0.8.3",
    "eslint": "8.57.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-astro": "1.1.2",
    "eslint-plugin-jsx-a11y": "6.8.0",
    "prettier": "^3.2.5",
    "prettier-plugin-astro": "^0.13.0",
    "prettier-plugin-astro-organize-imports": "0.4.7",
    "prettier-plugin-tailwindcss": "0.5.14",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5",
    "typescript-eslint": "^7.8.0"
  }
